    public static void menuCategorias() {

        boolean estado = true;

        while (estado) {

            System.out.println();
            System.out.println("========= CINEPLANET =========");
            System.out.println("Cliente: " + tipoCliente);
            if (esAdmin) {
                System.out.println("0. Panel del adminstrador");
            }
            System.out.println("1.- Registrarse");
            System.out.println("2.- Iniciar sesion");
            System.out.println("3.- Modo invitado");
            System.out.println("4.- Salir");
            System.out.print("Seleccione opcion: ");

            int opcion = sc.nextInt();
            sc.nextLine();

            switch (opcion) {
                case 0:
                    if (esAdmin == true) {
                        menuAdminCRUD();
                    } else {
                        System.out.println("Opcion no valida");
                    }
                    break;
                case 1:
                    registrarse();
                    break;
                case 2:
                    iniciarSesion();
                    break;
                case 3:
                    tipoCliente = "Invitado";
                    menuPrincipal();
                    break;
                case 4:
                    estado = false;
                    System.out.println("Gracias por visitar Cineplanet");
                    break;
                default:
                    System.out.println("Opcion invalida");
            }
        }
    }

