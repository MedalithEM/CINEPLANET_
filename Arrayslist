            escritor.write(String.format("%-20s S/%10.2f%n",
                    "Vuelto:", vuelto));

            escritor.write("=====================================\n");
            escritor.write(String.format("%25s%n", "Gracias por su compra"));
            escritor.write("=====================================\n");

        } catch (IOException e) {
            e.printStackTrace();
        }

        System.out.println("El archivo se exportó correctamente en: D:\\Cineplanet.txt");
    }
    public static void escritorLineaLarga(FileWriter escritor, String titulo, String texto) throws IOException {

        int ancho = 14; // caracteres por línea


        if(texto.length() <= ancho){

            escritor.write(String.format("%-20s %s%n",
                    titulo, texto));

        }else{


            escritor.write(String.format("%-20s %s%n",
                    titulo,
                    texto.substring(0, ancho)));


            int inicio = ancho;


            while(inicio < texto.length()){

                int fin = Math.min(inicio + ancho, texto.length());


                escritor.write(String.format("%-20s %s%n",
                        "",
                        texto.substring(inicio, fin)));

                inicio += ancho;
            }

        }
    }

