    public static void crearPelicula(){
        System.out.println("1.- Cartelera");
        System.out.println("2.- Preventa");
        System.out.println("3.- Estreno");
        int opcion=sc.nextInt();
        sc.nextLine();
        System.out.println("Nombre pelicula:");
        String nombre=sc.nextLine();
        System.out.println("Precio invitado:");
        double invitado=sc.nextDouble();
        System.out.println("Precio socio:");
        double socio=sc.nextDouble();

        switch(opcion){
            case 1:
                peliculasCartelera.add(nombre);
                precioCarteleraInvitado.add(invitado);
                precioCarteleraSocio.add(socio);
                break;
            case 2:
                peliculasPreventa.add(nombre);
                precioPreventaInvitado.add(invitado);
                precioPreventaSocio.add(socio);
                break;
            case 3:
                peliculasEstreno.add(nombre);
                precioEstrenoInvitado.add(invitado);
                precioEstrenoSocio.add(socio);

                break;
            default:
                System.out.println("Categoria invalida");
                return;
        }

        System.out.println("Pelicula agregada ✅");

    }
