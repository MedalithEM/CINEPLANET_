        public static void registrarse() {

            boolean correcto = false;

            while (!correcto) {
                System.out.print("Ingrese correo: ");
                correo = sc.nextLine();

                System.out.print("Ingrese contraseña: ");
                pass = sc.nextLine();

                boolean correoOK = correo.contains("@") && correo.endsWith(".com");
                boolean passOK = pass.length() >= 8;

                if (correoOK && passOK) {
                    correcto = true;
                    System.out.println("Registro correcto");
                } else {
                    System.out.println("Correo o contraseña invalida");
                }
            }
        }
        public static void iniciarSesion() {

            if (correo.equals("") || pass.equals("")) {
                System.out.println("Primero debe registrarse");
                return;
            }

            int intentos = 0;
            boolean acceso = false;

            while (intentos < 3 && !acceso) {

                System.out.print("Correo: ");
                String correoIngresado = sc.nextLine();

                System.out.print("Contraseña: ");
                String passIngresado = sc.nextLine();

                if (correoIngresado.equals("admin") && passIngresado.equals("123456")) {
                    System.out.println("Bienvenido ADMIN");
                    esAdmin = true;
                    acceso=true;
                }
                if (correoIngresado.equals(correo) && passIngresado.equals(pass)) {
                    acceso = true;
                    tipoCliente = "Socio";
                    System.out.println("Inicio de sesion correcto");
                    menuPrincipal();
                } else {
                    intentos++;
                    System.out.println("Datos incorrectos. Intento " + intentos + " de 3");
                }
            }

            if (!acceso) {
                System.out.println("Cuenta bloqueada");
            }
        }
